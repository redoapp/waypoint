FROM golang:1.26-bookworm AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download
COPY . .
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 go build -o /out/waypoint ./cmd/waypoint

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /out/waypoint /usr/local/bin/waypoint
ENTRYPOINT ["waypoint"]
