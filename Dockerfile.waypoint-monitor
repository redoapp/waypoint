FROM golang:1.26-bookworm AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/waypoint-monitor ./cmd/waypoint-monitor

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /out/waypoint-monitor /usr/local/bin/waypoint-monitor
ENTRYPOINT ["waypoint-monitor"]
